# General
APP_VERSION=1.0.0
ENVIRONMENT=production
PORT=8000
HOST=0.0.0.0

# Database
DATABASE_URL=postgresql://user:password@host:5432/database

# Gateway secrets
GATEWAY_SECRET_KEY=replace-with-production-gateway-secret
GATEWAY_REQUEST_SIGNING_SECRET=replace-with-production-signing-secret
GATEWAY_JWT_ALGORITHM=HS256
GATEWAY_JWT_EXPIRES_MINUTES=60
GATEWAY_API_KEY_EXPIRY_DAYS=90
GATEWAY_REQUEST_BODY_LIMIT_BYTES=5242880
GATEWAY_FILE_SIZE_LIMIT_BYTES=25000000
GATEWAY_CACHE_TTL_SECONDS=120
GATEWAY_RATE_LIMIT_MINUTE=120
GATEWAY_RATE_LIMIT_HOUR=2000
GATEWAY_RATE_LIMIT_DAY=10000
GATEWAY_BURST_LIMIT=30
GATEWAY_ALLOWED_ORIGINS=https://example.com
GATEWAY_CORS_ALLOW_CREDENTIALS=false
GATEWAY_ALLOWED_IPS=
GATEWAY_ENABLE_CSRF=true
GATEWAY_UPLOAD_DIR=/tmp/data/gateway_uploads

# Data directories
DATA_RAW_DIR=/tmp/datesets_folder
DATA_PROCESSED_DIR=/tmp/data/processed
DATA_ERROR_LOGS_DIR=/tmp/data/error_logs

# External services
REDIS_URL=redis://localhost:6379/0
AI_PROVIDER_TIMEOUT_SECONDS=60

# AI provider keys (optional if not using specific providers)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/models
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
XAI_API_KEY=
XAI_BASE_URL=https://api.x.ai/v1
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OLLAMA_BASE_URL=http://localhost:11434
CUSTOM_OPENAI_API_KEY=
CUSTOM_OPENAI_BASE_URL=http://localhost:8001/v1
